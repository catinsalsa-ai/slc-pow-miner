# SLC/Silicoin miner config — copy to .env on your VPS and edit manually.
# NEVER paste private keys into chat.

# Ethereum mainnet RPC. Public RPC is okay for status, private RPC recommended for mining.
RPC_URL=https://ethereum-rpc.publicnode.com

# Burner wallet private key only. Required for npm run mine. Not required for npm run status.
PRIVATE_KEY=

# Safety caps
# Set BUDGET_ETH=0 to disable the session spend cap. Not recommended for first live runs.
BUDGET_ETH=0.003
MAX_GAS_GWEI=3
PRIORITY_FEE_GWEI=0.2

# Transaction guard: miner will NOT send tx unless RUN_TX=true.
# You can also force live mode with: npm run mine:live
RUN_TX=false

# CPU mining controls
WORKERS=0
BATCH_SIZE=50000
ANCHOR_REFRESH_BLOCKS=20

# Optional public dashboard telemetry at https://www.silicoin.network/ miners section.
# OFF by default. Set REPORT=on to show your wallet/miner publicly.
# Sends signed stats only; never sends PRIVATE_KEY.
REPORT=off
MINER_NAME=maulana-vps

# Optional CUDA backend. Build with: npm run build:cuda
GPU=false
# Safe default. For RTX 5090 live mining, prefer npm run mine:v2 (268M persistent) or mine:v2:turbo (536M persistent).
CUDA_BATCH=4194304
# Keep CUDA helper alive between rounds to reduce process spawn/init overhead.
CUDA_PERSISTENT=true
CUDA_MINER_BIN=

# Cleaner logs: print mining summary every N seconds instead of every CUDA batch
LOG_EVERY_SEC=5
