# SLC/Silicoin miner config — copy to .env on your VPS and edit manually.
# NEVER paste private keys into chat.

# Ethereum mainnet RPC. Public RPC is okay for status, private RPC recommended for mining.
RPC_URL=https://ethereum-rpc.publicnode.com

# Burner wallet private key only. Required for npm run mine. Not required for npm run status.
PRIVATE_KEY=

# Safety caps
# Set BUDGET_ETH=0 to disable the session spend cap. Not recommended for first live runs.
BUDGET_ETH=0.003
MAX_GAS_GWEI=3
PRIORITY_FEE_GWEI=0.2

# Transaction guard: miner will NOT send tx unless RUN_TX=true.
# You can also force live mode with: npm run mine:live
RUN_TX=false

# CPU mining controls
WORKERS=0
BATCH_SIZE=50000
ANCHOR_REFRESH_BLOCKS=20

# Optional dashboard telemetry from original skill. Kept OFF by default.
REPORT=off
MINER_NAME=maulana-vps

# Optional CUDA backend. Build with: npm run build:cuda
GPU=false
CUDA_BATCH=4194304
CUDA_MINER_BIN=
